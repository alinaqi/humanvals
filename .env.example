# humanvals — copy to .env and fill in values (all optional)

# Path to the humanvals SQLite database (default: ./humanvals.db)
HUMANVALS_DB=humanvals.db

# Optional: real LLM access for examples/live_agent.py via any OpenAI-compatible
# gateway (srooter, LiteLLM, OpenRouter, ...). The framework examples run
# WITHOUT keys by default (they use each framework's test/fake model).
OPENAI_BASE_URL=
OPENAI_API_KEY=
HUMANVALS_MODEL=glm-5.2

# Deployment (Render) — server-side only
RENDER_API_KEY=
